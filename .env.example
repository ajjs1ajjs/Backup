# NovaBackup Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# ===========================================
# Security - CRITICAL: Change these defaults!
# ===========================================

# Master encryption key for encrypted backups (min 32 characters)
# Generate with: openssl rand -hex 32 or python -c "import secrets; print(secrets.token_hex(32))"
NOVABACKUP_MASTER_KEY=REPLACE_WITH_SECURE_KEY_32_CHARS_MIN

# JWT secret for token signing (min 32 characters)
# Generate with: openssl rand -hex 32 or python -c "import secrets; print(secrets.token_hex(32))"
NOVABACKUP_JWT_SECRET=REPLACE_WITH_SECURE_KEY_32_CHARS_MIN

# API key for external access (min 16 characters)
NOVABACKUP_API_KEY=REPLACE_WITH_SECURE_API_KEY

# ===========================================
# Database Configuration
# ===========================================

# SQLite (default, for development)
NOVABACKUP_DATABASE_URL=sqlite:///./novabackup.db

# PostgreSQL (for production)
# NOVABACKUP_DATABASE_URL=postgresql://user:password@localhost:5432/novabackup

# ===========================================
# Server Configuration
# ===========================================

# Server host and port
NOVABACKUP_HOST=0.0.0.0
NOVABACKUP_PORT=8050

# Enable HTTPS (set to true in production with valid certificates)
NOVABACKUP_HTTPS=false
NOVABACKUP_HTTPS_PORT=8443

# ===========================================
# Cloud Providers (comma-separated)
# ===========================================

# Available: MOCK, AWS, AZURE, GCP
NOVABACKUP_CLOUD_PROVIDERS=MOCK

# ===========================================
# AWS Configuration (if using AWS)
# ===========================================

# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1

# ===========================================
# Azure Configuration (if using Azure)
# ===========================================

# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_SUBSCRIPTION_ID=your-subscription-id

# ===========================================
# Google Cloud Configuration (if using GCP)
# ===========================================

# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=your-project-id

# ===========================================
# Notification Configuration
# ===========================================

# SMTP Configuration for email notifications
# NOVABACKUP_SMTP_HOST=smtp.example.com
# NOVABACKUP_SMTP_PORT=587
# NOVABACKUP_SMTP_USER=notifications@example.com
# NOVABACKUP_SMTP_PASSWORD=your-smtp-password
# NOVABACKUP_SMTP_FROM=novabackup@example.com

# Telegram Bot Configuration
# NOVABACKUP_TELEGRAM_BOT_TOKEN=your-bot-token
# NOVABACKUP_TELEGRAM_CHAT_ID=your-chat-id

# ===========================================
# Backup Storage Configuration
# ===========================================

# Base directory for backups
NOVABACKUP_BACKUP_DIR=./data/backups

# Data directory
NOVABACKUP_DATA_DIR=./data

# Logs directory
NOVABACKUP_LOGS_DIR=./data/logs

# ===========================================
# Retention Policy
# ===========================================

# Retention type: days, copies
NOVABACKUP_RETENTION_TYPE=days
NOVABACKUP_RETENTION_VALUE=30

# Maximum number of backup copies to keep
NOVABACKUP_MAX_COPIES=10
