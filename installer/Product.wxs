<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="NovaBackup v4.0"
    Version="4.0.0.0"
    Manufacturer="NovaBackup Team"
    UpgradeCode="a1b2c3d4-e5f6-7890-abcd-ef1234567890"
    Language="1033"
    InstallerVersion="500"
    Compressed="yes"
    UpgradeStrategy="majorUpgrade"
    Scope="perMachine">

    <!-- Require administrator privileges -->
    <Property Id="MSIUSEREALADMINDETECTION" Value="1" />

    <!-- Major upgrade - remove old versions -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
      AllowSameVersionUpgrades="yes"
      RemoveFeatures="ALL" />

    <MediaTemplate EmbedCab="yes" />

    <!-- Custom UI -->
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="assets\Banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="assets\Dialog.bmp" />
    <WixVariable Id="WixUIExclamationIco" Value="assets\Error.ico" />
    <WixVariable Id="WixUIInfoIco" Value="assets\Warning.ico" />
    <WixVariable Id="WixUINewIco" Value="assets\Icon16x16.ico" />
    <WixVariable Id="WixUIUpIco" Value="assets\Icon16x16.ico" />

    <!-- Task Scheduler for automatic backup execution -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="NovaBackup">
        <!-- Scheduled Task Component -->
        <Component Id="ScheduledTaskComponent" Guid="bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb">
          <RegistryValue Root="HKLM" Key="Software\NovaBackup\Agent" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
          <Environment
            Id="SetNovaBackupPath"
            Name="NOVABACKUP_PATH"
            Value="[INSTALLFOLDER]"
            Permanent="yes"
            Part="all"
            Action="set" />
        </Component>

        <!-- NovaBackup Agent Service -->
        <Component Id="NovaBackupAgentService" Guid="cccccccc-cccc-cccc-cccc-cccccccccccc">
          <File Id="NovaBackupAgent.exe" Source="$(var.PublishDir)\NovaBackup.Agent.exe" KeyPath="yes" />
          <ServiceInstall
            Id="NovaBackupAgentServiceInstall"
            Type="ownProcess"
            Name="NovaBackup Agent"
            DisplayName="NovaBackup Agent Service"
            Description="NovaBackup backup agent service for scheduled backups and monitoring. Works like Veeam Backup Service."
            ErrorControl="ignore"
            Start="auto"
            Account="LocalSystem" />
          <ServiceControl
            Id="StartAgentService"
            Name="NovaBackup Agent"
            Start="install"
            Stop="both"
            Remove="uninstall"
            Wait="yes" />
          <!-- Configure service recovery via registry -->
          <RegistryValue Root="HKLM" Key="System\CurrentControlSet\Services\NovaBackup Agent" Name="FailureActions" Type="binary" Value="000000000000000000000000000000000000000000000000010000000200000003000000000000000000000001000000" KeyPath="no" />
        </Component>
        <Component Id="RemoveFolderOnUninstall" Guid="*">
          <RemoveFolder Id="RemoveINSTALLFOLDER" On="uninstall" />
          <RegistryValue Root="HKLM" Key="Software\NovaBackup" Name="InstallPath" Type="string" Value="[INSTALLFOLDER]" KeyPath="yes" />
        </Component>

        <!-- Main Application -->
        <Component Id="NovaBackupGUI" Guid="*">
          <File Id="NovaBackupGUI.exe" Source="$(var.PublishDir)\NovaBackup.GUI.exe" KeyPath="yes">
            <Shortcut Id="StartMenuShortcut" Directory="ProgramMenuFolder" Name="NovaBackup" WorkingDirectory="INSTALLFOLDER" />
            <Shortcut Id="DesktopShortcut" Directory="DesktopFolder" Name="NovaBackup" WorkingDirectory="INSTALLFOLDER" />
          </File>
        </Component>

        <!-- All DLLs from publish -->
        <Component Id="AllDLLs" Guid="11111111-1111-1111-1111-111111111111">
          <!-- NovaBackup -->
          <File Id="NovaBackupCore.dll" Source="$(var.PublishDir)\NovaBackup.Core.dll" KeyPath="yes" />
          <File Id="NovaBackupEngine.dll" Source="$(var.PublishDir)\NovaBackup.Engine.dll" />
          <File Id="NovaBackupCommon.dll" Source="$(var.PublishDir)\NovaBackup.Common.dll" />
          <File Id="NovaBackupStorage.dll" Source="$(var.PublishDir)\NovaBackup.Storage.dll" />
          <File Id="NovaBackupScheduler.dll" Source="$(var.PublishDir)\NovaBackup.Scheduler.dll" />
          <File Id="NovaBackupCloud.dll" Source="$(var.PublishDir)\NovaBackup.Cloud.dll" />
          <File Id="NovaBackupDeduplication.dll" Source="$(var.PublishDir)\NovaBackup.Deduplication.dll" />
          <File Id="NovaBackupLicensing.dll" Source="$(var.PublishDir)\NovaBackup.Licensing.dll" />
          <File Id="NovaBackupReplication.dll" Source="$(var.PublishDir)\NovaBackup.Replication.dll" />
          <File Id="NovaBackupVirtualization.dll" Source="$(var.PublishDir)\NovaBackup.Virtualization.dll" />
          <File Id="NovaBackupAgent.dll" Source="$(var.PublishDir)\NovaBackup.Agent.dll" />
          <File Id="NovaBackupGUI.dll" Source="$(var.PublishDir)\NovaBackup.GUI.dll" />

          <!-- Microsoft Extensions -->
          <File Id="Microsoft.Data.Sqlite.dll" Source="$(var.PublishDir)\Microsoft.Data.Sqlite.dll" />
          <File Id="Microsoft.Extensions.Configuration.Abstractions.dll" Source="$(var.PublishDir)\Microsoft.Extensions.Configuration.Abstractions.dll" />
          <File Id="Microsoft.Extensions.Configuration.Binder.dll" Source="$(var.PublishDir)\Microsoft.Extensions.Configuration.Binder.dll" />
          <File Id="Microsoft.Extensions.Configuration.dll" Source="$(var.PublishDir)\Microsoft.Extensions.Configuration.dll" />
          <File Id="Microsoft.Extensions.DependencyInjection.Abstractions.dll" Source="$(var.PublishDir)\Microsoft.Extensions.DependencyInjection.Abstractions.dll" />
          <File Id="Microsoft.Extensions.DependencyInjection.dll" Source="$(var.PublishDir)\Microsoft.Extensions.DependencyInjection.dll" />
          <File Id="Microsoft.Extensions.Diagnostics.Abstractions.dll" Source="$(var.PublishDir)\Microsoft.Extensions.Diagnostics.Abstractions.dll" />
          <File Id="Microsoft.Extensions.Diagnostics.dll" Source="$(var.PublishDir)\Microsoft.Extensions.Diagnostics.dll" />
          <File Id="Microsoft.Extensions.Http.dll" Source="$(var.PublishDir)\Microsoft.Extensions.Http.dll" />
          <File Id="Microsoft.Extensions.Logging.Abstractions.dll" Source="$(var.PublishDir)\Microsoft.Extensions.Logging.Abstractions.dll" />
          <File Id="Microsoft.Extensions.Logging.dll" Source="$(var.PublishDir)\Microsoft.Extensions.Logging.dll" />
          <File Id="Microsoft.Extensions.Options.ConfigurationExtensions.dll" Source="$(var.PublishDir)\Microsoft.Extensions.Options.ConfigurationExtensions.dll" />
          <File Id="Microsoft.Extensions.Options.dll" Source="$(var.PublishDir)\Microsoft.Extensions.Options.dll" />
          <File Id="Microsoft.Extensions.Primitives.dll" Source="$(var.PublishDir)\Microsoft.Extensions.Primitives.dll" />

          <!-- Other -->
          <File Id="Newtonsoft.Json.dll" Source="$(var.PublishDir)\Newtonsoft.Json.dll" />
          <File Id="SQLitePCLRaw.batteries_v2.dll" Source="$(var.PublishDir)\SQLitePCLRaw.batteries_v2.dll" />
          <File Id="SQLitePCLRaw.core.dll" Source="$(var.PublishDir)\SQLitePCLRaw.core.dll" />
          <File Id="SQLitePCLRaw.provider.e_sqlite3.dll" Source="$(var.PublishDir)\SQLitePCLRaw.provider.e_sqlite3.dll" />
          <File Id="e_sqlite3.dll" Source="$(var.PublishDir)\e_sqlite3.dll" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuNovaBackup" Name="NovaBackup">
        <Component Id="UninstallShortcut" Guid="*">
          <RemoveFolder Id="RemoveProgramMenuNovaBackup" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\NovaBackup" Name="ProgramMenu" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainApplication" Title="NovaBackup Application" Level="1" AllowAdvertise="no" Display="expand">
      <ComponentRef Id="RemoveFolderOnUninstall" />
      <ComponentRef Id="NovaBackupGUI" />
      <ComponentRef Id="AllDLLs" />
      <ComponentRef Id="UninstallShortcut" />
      <ComponentRef Id="ScheduledTaskComponent" />
      <ComponentRef Id="NovaBackupAgentService" />
    </Feature>
  </Package>
</Wix>
