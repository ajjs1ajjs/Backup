<Window x:Class="NovaBackup.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NovaBackup.GUI"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="NovaBackup v6.0 Enterprise - Backup &amp; Recovery Platform" 
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E"
        Foreground="White"
        xmlns:viewmodels="clr-namespace:NovaBackup.GUI.ViewModels"
        xmlns:views="clr-namespace:NovaBackup.GUI.Views">
    
    <Window.Resources>
        <!-- DataTemplates for MVVM Routing -->
        <DataTemplate DataType="{x:Type viewmodels:HomeViewModel}">
            <views:HomeView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:JobsViewModel}">
            <views:JobsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:InfrastructureViewModel}">
            <views:InfrastructureView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:StorageViewModel}">
            <views:StorageView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:RecoverySessionsViewModel}">
            <views:RecoverySessionsView/>
        </DataTemplate>

        <!-- Navigation Button Style (Veeam-like) -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFB0B0B0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF2D2D2D"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="Tag" Value="Selected">
                    <Setter Property="Background" Value="#FF00A8E6"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Main Content -->
            <RowDefinition Height="Auto"/>  <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- HEADER (Veeam-style blue gradient) -->
        <Border Grid.Row="0" Height="80">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF0066CC" Offset="0"/>
                    <GradientStop Color="#FF00A8E6" Offset="0.5"/>
                    <GradientStop Color="#FF0066CC" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Logo & Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="20,0">
                    <materialDesign:PackIcon Kind="Shield" Width="40" Height="40" VerticalAlignment="Center" Foreground="White"/>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="NovaBackup" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="v6.0 Enterprise" FontSize="12" Opacity="0.9" Foreground="White"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <Button x:Name="btnStartBackup" Style="{StaticResource ActionButtonStyle}" 
                            Background="#FF28A745" BorderBrush="#FF28A745">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Play" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="START BACKUP"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="btnCreateJob" Style="{StaticResource ActionButtonStyle}" 
                            Background="#FF0078D4" BorderBrush="#FF0078D4" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="CREATE JOB"/>
                        </StackPanel>
                    </Button>
                    
                    <Button x:Name="btnSettings" Style="{StaticResource ActionButtonStyle}" 
                            Background="#FF6C757D" BorderBrush="#FF6C757D" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cog" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="SETTINGS"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>  <!-- Sidebar -->
                <ColumnDefinition Width="*"/>     <!-- Content -->
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR (Dark) -->
            <Border Grid.Column="0" Background="#FF2D2D2D">
                <StackPanel>
                    <!-- Dashboard Button -->
                    <Button x:Name="btnDashboard" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateHomeCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Backup Jobs -->
                    <Button x:Name="btnJobs" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateJobsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BackupRestore" Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Backup Jobs" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Background="#FF3D3D3D" Margin="10,10" Height="1"/>

                    <!-- Infrastructure -->
                    <Button x:Name="btnInfrastructure" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateInfrastructureCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Server" Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Infrastructure" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Backup Repositories -->
                    <Button x:Name="btnStorage" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateStorageCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseOutline" Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Backup Repositories" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Instant Recovery Sessions -->
                    <Button x:Name="btnRecovery" Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateRecoveryCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="LightningBolt" Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Instant Recovery" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- CONTENT AREA -->
            <Grid Grid.Column="1" Background="#FF1E1E1E">
                <ContentControl Content="{Binding CurrentViewModel}" />
            </Grid>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Height="30" Background="#FF1E1E1E" BorderBrush="#FF3D3D3D" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="Ready" VerticalAlignment="Center" Margin="10,0" Foreground="#FFAAAAAA" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="Version 6.0.0" VerticalAlignment="Center" Margin="10,0" Foreground="#FFAAAAAA" FontSize="11"/>
                <TextBlock Grid.Column="2" Text="© 2026 NovaBackup Technologies" VerticalAlignment="Center" Margin="10,0" Foreground="#FFAAAAAA" FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</Window>
