<Window x:Class="NovaBackup.GUI.Views.AddServerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Add New Server" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1E1E1E"
        Foreground="White"
        TextElement.Foreground="White">
    
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="ADD NEW SERVER" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <TextBlock Text="Server Name" Margin="0,5"/>
            <TextBox Text="{Binding ServerName}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,10"/>
            
            <TextBlock Text="IP Address / Hostname" Margin="0,5"/>
            <TextBox Text="{Binding ServerAddress}" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,10"/>
            
            <TextBlock Text="Server Type" Margin="0,5"/>
            <ComboBox SelectedValue="{Binding ServerType}" SelectedValuePath="Content" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,10">
                <ComboBoxItem Content="Hyper-V"/>
                <ComboBoxItem Content="VMware vSphere"/>
            </ComboBox>
            
            <TextBlock Text="Credentials (Optional)" FontWeight="SemiBold" Margin="0,10,0,5"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Text="Username" FontSize="10"/>
                    <TextBox Text="{Binding Username}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <TextBlock Text="Password" FontSize="10"/>
                    <PasswordBox x:Name="PassBox" Style="{StaticResource MaterialDesignOutlinedPasswordBox}"/>
                </StackPanel>
            </Grid>
            
            <TextBlock Text="{Binding StatusMessage}" Foreground="#FF00A8E6" Margin="0,10" TextAlignment="Center"/>
            
            <UniformGrid Columns="2" Margin="0,20,0,0">
                <Button Content="CANCEL" Command="{Binding CancelCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#FFAAAAAA"/>
                <Button Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding AddServerCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Check" Margin="0,0,8,0"/>
                        <TextBlock Text="ADD"/>
                    </StackPanel>
                </Button>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
