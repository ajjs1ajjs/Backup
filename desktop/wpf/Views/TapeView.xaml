<Window x:Class="NovaBackup.GUI.Views.TapeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tape Management" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#FF1E1E1E" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Tape Management" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <Button Content="Refresh" Command="{Binding LoadDataCommand}" Margin="30,0,0,0" Padding="15,5"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="#FF97A4" Margin="0,0,0,10"/>

        <!-- Content -->
        <TabControl Grid.Row="2" Background="#FF2D2D2D" Foreground="White">
            <!-- Libraries Tab -->
            <TabItem Header="Libraries">
                <DataGrid ItemsSource="{Binding Libraries}" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="#FF2D2D2D" Foreground="White" GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="150"/>
                        <DataGridTextColumn Header="Slots" Binding="{Binding Slots}" Width="80"/>
                        <DataGridTextColumn Header="Drives" Binding="{Binding DriveCount}" Width="80"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Cartridges Tab -->
            <TabItem Header="Cartridges">
                <DataGrid ItemsSource="{Binding Cartridges}" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="#FF2D2D2D" Foreground="White" GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="120"/>
                        <DataGridTextColumn Header="Slot" Binding="{Binding Slot}" Width="60"/>
                        <DataGridTextColumn Header="Media Type" Binding="{Binding MediaType}" Width="100"/>
                        <DataGridTextColumn Header="Capacity (GB)" Binding="{Binding CapacityGb}" Width="100"/>
                        <DataGridTextColumn Header="Used (GB)" Binding="{Binding UsedGb}" Width="100"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                        <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Vaults Tab -->
            <TabItem Header="Vaults">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <TextBox Width="200" Text="{Binding NewVaultName, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="#FF3D3D3D" Foreground="White" Padding="5"/>
                        <Button Content="Create Vault" Command="{Binding CreateVaultCommand}" Margin="10,0,0,0" Padding="15,5"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Vaults}" AutoGenerateColumns="False" IsReadOnly="True"
                              Background="#FF2D2D2D" Foreground="White">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="150"/>
                            <DataGridTextColumn Header="Contact" Binding="{Binding Contact}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Jobs Tab -->
            <TabItem Header="Jobs">
                <DataGrid ItemsSource="{Binding Jobs}" AutoGenerateColumns="False" IsReadOnly="True"
                          Background="#FF2D2D2D" Foreground="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120"/>
                        <DataGridTextColumn Header="Target Vault" Binding="{Binding TargetVault}" Width="120"/>
                        <DataGridTextColumn Header="Schedule" Binding="{Binding Schedule}" Width="100"/>
                        <DataGridTextColumn Header="Retention (days)" Binding="{Binding RetentionDays}" Width="100"/>
                        <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="60"/>
                        <DataGridTemplateColumn Header="Actions" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Run" Command="{Binding DataContext.RunJobCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                            CommandParameter="{Binding Id}" Padding="10,2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#FF97A4" VerticalAlignment="Center"/>
            <Button Content="Close" Margin="20,0,0,0" Padding="20,5" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
