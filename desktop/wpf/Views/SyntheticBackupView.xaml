<Window x:Class="NovaBackup.GUI.Views.SyntheticBackupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Synthetic Backup Management" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#FF1E1E1E" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Synthetic Full Backup" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="30,0,0,0" Padding="15,5"/>
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Create Synthetic Backup" Command="{Binding CreateSyntheticBackupCommand}"
                    Padding="15,8" Margin="0,0,10,0" Background="#FF00A8E6" Foreground="White"/>
            <Button Content="Merge Incrementals" Command="{Binding MergeIncrementalsCommand}"
                    Padding="15,8" Margin="0,0,10,0" Background="#FF28A745" Foreground="White"/>
            <Button Content="Delete" Command="{Binding DeleteSyntheticBackupCommand}"
                    Padding="15,8" Background="#FFDC3545" Foreground="White"/>
        </StackPanel>

        <!-- Content -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Backups}" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#FF2D2D2D" Foreground="White" GridLinesVisibility="Horizontal"
                  SelectedItem="{Binding SelectedBackup, Mode=TwoWay}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="Source Repo" Binding="{Binding SourceRepo}" Width="120"/>
                <DataGridTextColumn Header="Target Repo" Binding="{Binding TargetRepo}" Width="120"/>
                <DataGridTextColumn Header="Type" Binding="{Binding BackupType}" Width="80"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Size (GB)" Binding="{Binding Size, StringFormat={}{0:N2} GB}" Width="100"/>
                <DataGridTextColumn Header="Compression" Binding="{Binding CompressionRatio, StringFormat={}{0:P1}}" Width="100"/>
                <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="150"/>
                <DataGridTextColumn Header="Completed" Binding="{Binding CompletedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#FF97A4" VerticalAlignment="Center" Margin="0,0,20,0"/>
            <Button Content="Close" Padding="20,5" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
