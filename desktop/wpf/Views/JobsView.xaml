<UserControl x:Class="NovaBackup.GUI.Views.JobsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:NovaBackup.GUI.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:JobsViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1100">

    <Grid Background="#FF1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="{Binding PageTitle}" FontSize="28" FontWeight="Bold" 
                   Margin="30,20" Foreground="White"/>
        
        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="30,0,30,15">
            <Button Content="Backup Job" Command="{Binding CreateBackupJobCommand}" Background="#FF28A745" BorderThickness="0" Padding="15,5" Foreground="White" Margin="0,0,10,0"/>
            <Button Content="Replication Job" Background="#FF0078D4" BorderThickness="0" Padding="15,5" Foreground="White" Margin="0,0,10,0"/>
            <Button Content="SureBackup" Background="#FF6C757D" BorderThickness="0" Padding="15,5" Foreground="White" Margin="0,0,10,0"/>
        </StackPanel>
        
        <!-- Jobs Table and Restore Points -->
        <Border Grid.Row="2" Background="#FF2D2D2D" CornerRadius="4" Padding="20" Margin="30,0,30,30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="dgJobs" Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True" 
                          ItemsSource="{Binding Jobs}" SelectedItem="{Binding SelectedJob}"
                          Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF3D3D3D" RowBackground="Transparent">
                    
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Start Job" Command="{Binding StartJobCommand}" CommandParameter="{Binding SelectedJob}"/>
                            <MenuItem Header="Edit" Command="{Binding EditJobCommand}" CommandParameter="{Binding SelectedJob}"/>
                            <Separator/>
                            <MenuItem Header="Delete" Command="{Binding DeleteJobCommand}" CommandParameter="{Binding SelectedJob}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="150"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Last Run" Binding="{Binding LastRun, StringFormat='\{0:yyyy-MM-dd HH:mm\}'}" Width="150"/>
                        <DataGridTextColumn Header="Size (GB)" Binding="{Binding SizeGB, StringFormat='\{0:F1\}'}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <GridSplitter Grid.Row="1" Height="2" HorizontalAlignment="Stretch" Background="#FF3D3D3D" Margin="0,10"/>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Restore Points" Foreground="#FF0078D4" FontWeight="Bold" Margin="0,0,0,5"/>
                    <DataGrid Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              ItemsSource="{Binding RestorePoints}" SelectedItem="{Binding SelectedRestorePoint}"
                              Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#FF3D3D3D" RowBackground="Transparent">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Instant VM Recovery..." Command="{Binding InstantRecoverCommand}" CommandParameter="{Binding SelectedRestorePoint}"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Point Time" Binding="{Binding PointTime, StringFormat='\{0:yyyy-MM-dd HH:mm\}'}" Width="200"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
