<Window x:Class="NovaBackup.GUI.Views.RecoverySessionsWindowMinimal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Active Recovery Sessions" Height="300" Width="500"
        WindowStartupLocation="CenterOwner" Background="#FF1E1E1E" Foreground="White">
  <Grid Margin="10">
    <StackPanel>
      <TextBlock Text="Active Recovery Sessions" FontWeight="Bold" Margin="0,0,0,8"/>
      <ListView x:Name="SessionsList" Height="180" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
        <Button Content="Refresh" Width="80" Margin="0,0,6,0" Click="Refresh_Click"/>
        <Button Content="Stop" Width="80" Margin="0,0,6,0" Click="Stop_Click"/>
        <Button Content="Close" Width="80" Click="Close_Click"/>
      </StackPanel>
    </StackPanel>
    <TextBlock x:Name="ToastBlock" Foreground="White" Background="#AA333333" Padding="6,2" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6,0,0" Visibility="Collapsed"/>
  </Grid>
</Window>
