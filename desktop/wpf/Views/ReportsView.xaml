<Window x:Class="NovaBackup.GUI.Views.ReportsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reports" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#FF1E1E1E" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Reports" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <Button Content="Refresh" Command="{Binding LoadDataCommand}" Margin="30,0,0,0" Padding="15,5"/>
            <Button Content="Generate Report" Command="{Binding GenerateReportCommand}" Margin="10,0,0,0" Padding="15,5"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="#FF97A4" Margin="0,0,0,10"/>

        <!-- Reports Grid -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding Reports}" SelectedItem="{Binding SelectedReport}" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#FF2D2D2D" Foreground="White" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="120"/>
                <DataGridTextColumn Header="Generated" Binding="{Binding Generated, StringFormat='yyyy-MM-dd HH:mm'}" Width="160"/>
                <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="80"/>
                <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Button Grid.Row="3" Content="Close" HorizontalAlignment="Right" Padding="20,5" Click="CloseButton_Click" Margin="0,10,0,0"/>
    </Grid>
</Window>
