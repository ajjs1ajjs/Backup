<Window x:Class="NovaBackup.GUI.Views.RecoverySessionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Active Recovery Sessions" Height="400" Width="600"
        WindowStartupLocation="CenterOwner" Background="#FF1E1E1E" 
        Foreground="White">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Text="Active Recovery Sessions" FontSize="16" FontWeight="Bold"/>
    <ListView Grid.Row="1" ItemsSource="{Binding Sessions}">
      <ListView.ItemTemplate>
        <DataTemplate>
          <Grid Margin="0,5,0,5">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical">
              <TextBlock Text="{Binding VMName}" FontWeight="Bold"/>
              <TextBlock Text="{Binding Status}" FontSize="12"/>
            </StackPanel>
            <ProgressBar Grid.Column="1" Value="{Binding Progress}" Maximum="1" Height="10" Margin="6,0"/>
            <Button Grid.Column="2" Content="Stop" Margin="6,0" Padding="6" Command="{Binding DataContext.StopSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding SessionID}"/>
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <TextBlock Grid.Row="2" Text="Status: {Binding StatusMessage}" Foreground="#FF97A4" Margin="0,6,0,0"/>
  </Grid>
</Window>
