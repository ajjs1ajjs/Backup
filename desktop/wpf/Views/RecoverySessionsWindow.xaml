<Window x:Class="NovaBackup.GUI.Views.RecoverySessionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NovaBackup.GUI.Converters"
        Title="Active Recovery Sessions" Height="400" Width="600"
        WindowStartupLocation="CenterOwner" Background="#FF1E1E1E" 
        Foreground="White">
  <Window.Resources>
    <local:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
  </Window.Resources>
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header with refresh -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
      <Button Content="Refresh" Command="{Binding RefreshSessionsAsyncCommand}" Width="90" Margin="0,0,8,0"/>
    </StackPanel>

    <!-- Toast message -->
    <Border Grid.Row="1" Background="#AA333333" CornerRadius="6" Padding="8" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0" 
            Visibility="{Binding ToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
      <TextBlock Text="{Binding ToastMessage}" Foreground="White"/>
    </Border>

    <!-- Title -->
    <TextBlock Grid.Row="1" Text="Active Recovery Sessions" FontSize="16" FontWeight="Bold" Margin="0,40,0,0"/>

    <!-- Sessions List -->
    <ListView Grid.Row="2" ItemsSource="{Binding Sessions}">
      <ListView.ItemTemplate>
        <DataTemplate>
          <Grid Margin="0,5,0,5">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Vertical">
              <TextBlock Text="{Binding VMName}" FontWeight="Bold"/>
              <TextBlock Text="{Binding Status}" FontSize="12" Foreground="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"/>
            </StackPanel>
            <ProgressBar Grid.Column="1" Value="{Binding Progress}" Maximum="1" Height="10" Margin="6,0"/>
            <Button Grid.Column="2" Content="Stop" Margin="6,0" Padding="6" Command="{Binding DataContext.StopSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding SessionID}"/>
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <!-- Footer -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#FF97A4" Margin="0,0,20,0" VerticalAlignment="Center"/>
      <Button Content="Refresh" Command="{Binding RefreshSessionsCommand}" Margin="0,0,6,0"/>
      <Button Content="Close" Command="{Binding CancelCommand}"/>
    </StackPanel>
  </Grid>
</Window>
