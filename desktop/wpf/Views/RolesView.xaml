<Window x:Class="NovaBackup.GUI.Views.RolesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Role Management" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#FF1E1E1E" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Role Management" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <Button Content="Refresh" Command="{Binding LoadDataCommand}" Margin="30,0,0,0" Padding="15,5"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="#FF97A4" Margin="0,0,0,10" VerticalAlignment="Top"/>

        <!-- Roles Grid -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" 
                  AutoGenerateColumns="False" IsReadOnly="True" Margin="0,30,0,0"
                  Background="#FF2D2D2D" Foreground="White" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Role ID" Binding="{Binding Id}" Width="150"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Permissions" Binding="{Binding Permissions}" Width="300"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Delete Selected" Command="{Binding DeleteRoleCommand}" Margin="0,0,10,0" Padding="15,5"/>
            <Button Content="Close" Padding="20,5" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
