<Window x:Class="NovaBackup.GUI.Views.RecoverySessionsWindowMVVM"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Active Recovery Sessions" Height="420" Width="640"
        WindowStartupLocation="CenterOwner" Background="#FF1E1E1E" Foreground="White">
  <Grid>
    <ListView ItemsSource="{Binding Sessions}">
      <ListView.ItemTemplate>
        <DataTemplate>
          <StackPanel Orientation="Horizontal" Margin="6,4">
            <TextBlock Text="{Binding VMName}" Width="200"/>
            <TextBlock Text="{Binding Status}" Width="120"/>
            <ProgressBar Value="{Binding Progress}" Width="200" Height="10"/>
            <Button Content="Stop" Command="{Binding StopSessionCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding SessionID}" Margin="6,0,0,0"/>
          </StackPanel>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>
  </Grid>
</Window>
