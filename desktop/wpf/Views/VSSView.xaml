<Window x:Class="NovaBackup.GUI.Views.VSSView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VSS Writers" Height="450" Width="600"
        WindowStartupLocation="CenterScreen" Background="#FF1E1E1E" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="VSS Writers" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <Button Content="Refresh" Command="{Binding LoadDataCommand}" Margin="30,0,0,0" Padding="15,5"/>
        </StackPanel>
        
        <DataGrid Grid.Row="1" ItemsSource="{Binding Writers}" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="#FF2D2D2D" Foreground="White" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding WriterType}" Width="150"/>
                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#FF97A4" VerticalAlignment="Center"/>
            <Button Content="Close" Click="CloseButton_Click" Margin="20,0,0,0" Padding="20,5"/>
        </StackPanel>
    </Grid>
</Window>
