# ===========================================
# NovaBackup Environment Configuration Examples
# ===========================================
# This file contains example configurations for different deployment scenarios.
# Copy the relevant section to your .env file and adjust values as needed.
# NEVER commit .env file to version control!
# ===========================================

# ===========================================
# 🔐 SECURITY - CRITICAL: Change these defaults!
# ===========================================

# Generate secure keys using:
# Windows (PowerShell): [System.Web.Security.Membership]::GeneratePassword(64, 10)
# Linux/macOS: openssl rand -hex 32
# Python: python -c "import secrets; print(secrets.token_hex(32))"

# Master encryption key for encrypted backups (minimum 32 characters)
NOVABACKUP_MASTER_KEY=REPLACE_WITH_SECURE_KEY_32_CHARS_MIN

# JWT secret for token signing (minimum 32 characters)
NOVABACKUP_JWT_SECRET=REPLACE_WITH_SECURE_KEY_32_CHARS_MIN

# API key for external access (minimum 16 characters)
NOVABACKUP_API_KEY=REPLACE_WITH_SECURE_API_KEY

# ===========================================
# 🏠 ENVIRONMENT 1: Local Development (SQLite)
# ===========================================
# Use this for local development and testing

# Environment
NOVABACKUP_ENV=development
NOVABACKUP_DEBUG=true

# Database (SQLite - file-based, no server needed)
NOVABACKUP_DATABASE_URL=sqlite:///./novabackup.db

# Server
NOVABACKUP_HOST=0.0.0.0
NOVABACKUP_PORT=8000
NOVABACKUP_HTTPS=false
NOVABACKUP_HTTPS_PORT=8443

# Cloud Providers (MOCK for testing, no real credentials needed)
NOVABACKUP_CLOUD_PROVIDERS=MOCK

# Backup Storage
NOVABACKUP_BACKUP_DIR=./data/backups
NOVABACKUP_DATA_DIR=./data
NOVABACKUP_LOGS_DIR=./data/logs

# Retention Policy
NOVABACKUP_RETENTION_TYPE=days
NOVABACKUP_RETENTION_VALUE=7
NOVABACKUP_MAX_COPIES=5

# CORS (allow all for development)
NOVABACKUP_CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000

# Rate Limiting (relaxed for development)
NOVABACKUP_RATE_LIMIT=100
NOVABACKUP_RATE_LIMIT_PERIOD=60

# ===========================================
# 🧪 ENVIRONMENT 2: Testing/CI (SQLite + MOCK)
# ===========================================
# Use this for automated testing and CI/CD pipelines

# Environment
NOVABACKUP_ENV=testing
NOVABACKUP_DEBUG=true
NOVABACKUP_TESTING_MODE=true

# Database (SQLite in-memory for fast tests)
NOVABACKUP_DATABASE_URL=sqlite:///:memory:

# Server
NOVABACKUP_HOST=127.0.0.1
NOVABACKUP_PORT=8000
NOVABACKUP_HTTPS=false

# Cloud Providers (MOCK for CI testing)
NOVABACKUP_CLOUD_PROVIDERS=MOCK

# Backup Storage (temporary directory)
NOVABACKUP_BACKUP_DIR=/tmp/novabackup/backups
NOVABACKUP_DATA_DIR=/tmp/novabackup/data
NOVABACKUP_LOGS_DIR=/tmp/novabackup/logs

# Retention (shorter for testing)
NOVABACKUP_RETENTION_TYPE=copies
NOVABACKUP_RETENTION_VALUE=3
NOVABACKUP_MAX_COPIES=3

# Disable notifications in tests
NOVABACKUP_NOTIFICATIONS_ENABLED=false

# ===========================================
# 🚀 ENVIRONMENT 3: Production (PostgreSQL + Real Cloud)
# ===========================================
# Use this for production deployments with real cloud providers

# Environment
NOVABACKUP_ENV=production
NOVABACKUP_DEBUG=false
NOVABACKUP_TESTING_MODE=false

# Database (PostgreSQL for production)
# Format: postgresql://user:password@host:port/database
NOVABACKUP_DATABASE_URL=postgresql://novabackup:STRONG_PASSWORD_HERE@localhost:5432/novabackup

# Database Pool Settings
NOVABACKUP_DB_POOL_SIZE=10
NOVABACKUP_DB_MAX_OVERFLOW=20
NOVABACKUP_DB_POOL_TIMEOUT=30
NOVABACKUP_DB_POOL_RECYCLE=3600

# Server
NOVABACKUP_HOST=0.0.0.0
NOVABACKUP_PORT=8050
NOVABACKUP_HTTPS=true
NOVABACKUP_HTTPS_PORT=8443

# Workers (adjust based on CPU cores)
NOVABACKUP_WORKERS=4

# Cloud Providers (comma-separated: AWS, AZURE, GCP)
NOVABACKUP_CLOUD_PROVIDERS=AWS,AZURE,GCP

# Backup Storage (production paths)
NOVABACKUP_BACKUP_DIR=/var/backups/novabackup
NOVABACKUP_DATA_DIR=/var/lib/novabackup
NOVABACKUP_LOGS_DIR=/var/log/novabackup

# Retention Policy (production settings)
NOVABACKUP_RETENTION_TYPE=days
NOVABACKUP_RETENTION_VALUE=30
NOVABACKUP_MAX_COPIES=10

# CORS (restrict to your domains)
NOVABACKUP_CORS_ORIGINS=https://backup.yourdomain.com,https://admin.yourdomain.com

# Rate Limiting (stricter for production)
NOVABACKUP_RATE_LIMIT=20
NOVABACKUP_RATE_LIMIT_PERIOD=60

# ===========================================
# ☁️ AWS Configuration
# ===========================================
# Required for AWS cloud provider

# AWS Credentials (Method 1: Access Key)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=us-east-1

# AWS Credentials (Method 2: Profile - comment out Method 1 if using)
# AWS_PROFILE=your-profile-name

# AWS Credentials (Method 3: IAM Role - for EC2/ECS/Lambda)
# No credentials needed, uses instance role
# AWS_USE_IAM_ROLE=true

# S3 Backup Settings
AWS_S3_BUCKET=novabackup-prod-backups
AWS_S3_PREFIX=backups/
AWS_S3_STORAGE_CLASS=STANDARD_IA

# ===========================================
# 🌐 Azure Configuration
# ===========================================
# Required for Azure cloud provider

# Azure Credentials (Service Principal)
AZURE_TENANT_ID=YOUR_TENANT_ID
AZURE_CLIENT_ID=YOUR_CLIENT_ID
AZURE_CLIENT_SECRET=YOUR_CLIENT_SECRET
AZURE_SUBSCRIPTION_ID=YOUR_SUBSCRIPTION_ID

# Azure Backup Settings
AZURE_RESOURCE_GROUP=novabackup-rg
AZURE_LOCATION=eastus
AZURE_STORAGE_ACCOUNT=novabackupprod
AZURE_CONTAINER=backups

# ===========================================
# 🌍 Google Cloud Configuration
# ===========================================
# Required for GCP cloud provider

# GCP Credentials
GOOGLE_APPLICATION_CREDENTIALS=/etc/novabackup/gcp-service-account.json
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=us-central1

# GCS Backup Settings
GCS_BUCKET=novabackup-prod-backups
GCS_PREFIX=backups/
GCS_STORAGE_CLASS=NEARLINE

# ===========================================
# 📧 Email Notifications (SMTP)
# ===========================================
# Configure for email notifications

# SMTP Server Settings
NOVABACKUP_SMTP_HOST=smtp.gmail.com
NOVABACKUP_SMTP_PORT=587
NOVABACKUP_SMTP_USE_TLS=true
NOVABACKUP_SMTP_USER=notifications@yourdomain.com
NOVABACKUP_SMTP_PASSWORD=YOUR_SMTP_PASSWORD
NOVABACKUP_SMTP_FROM=novabackup@yourdomain.com

# Email Recipients (comma-separated)
NOVABACKUP_SMTP_TO=admin@yourdomain.com,ops@yourdomain.com

# Notification Events
NOVABACKUP_NOTIFY_ON_SUCCESS=true
NOVABACKUP_NOTIFY_ON_FAILURE=true
NOVABACKUP_NOTIFY_ON_SCHEDULE=true

# ===========================================
# 📱 Telegram Notifications
# ===========================================
# Configure for Telegram bot notifications

# Bot Token (get from @BotFather)
NOVABACKUP_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Chat IDs (comma-separated, can be group chats)
NOVABACKUP_TELEGRAM_CHAT_IDS=-1001234567890,-1009876543210

# ===========================================
# 🔗 Webhook Notifications
# ===========================================
# Configure for Slack, Teams, or custom webhooks

# Webhook URL
NOVABACKUP_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Authentication Token (optional)
NOVABACKUP_WEBHOOK_AUTH_TOKEN=your-secret-token

# Custom Headers (JSON format)
# NOVABACKUP_WEBHOOK_HEADERS={"Content-Type":"application/json","X-Custom-Header":"value"}

# ===========================================
# ⏰ Scheduler Configuration
# ===========================================
# Backup scheduler settings

# Enable/Disable scheduler
NOVABACKUP_SCHEDULER_ENABLED=true

# Default backup schedule (cron format: minute hour day month weekday)
NOVABACKUP_DEFAULT_SCHEDULE=0 2 * * *

# Timezone for scheduler
NOVABACKUP_SCHEDULER_TIMEZONE=UTC

# Maximum concurrent jobs
NOVABACKUP_MAX_CONCURRENT_JOBS=3

# Job timeout (seconds)
NOVABACKUP_JOB_TIMEOUT=3600

# ===========================================
# 🔍 Monitoring & Observability
# ===========================================
# Prometheus, metrics, and logging settings

# Enable Prometheus metrics
NOVABACKUP_METRICS_ENABLED=true
NOVABACKUP_METRICS_PATH=/metrics

# Enable audit logging
NOVABACKUP_AUDIT_ENABLED=true
NOVABACKUP_AUDIT_LOG_FILE=./data/logs/audit.log
NOVABACKUP_AUDIT_MAX_ENTRIES=10000

# Enable health checks
NOVABACKUP_HEALTH_CHECK_ENABLED=true
NOVABACKUP_HEALTH_CHECK_PATH=/health

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
NOVABACKUP_LOG_LEVEL=INFO
NOVABACKUP_LOG_FORMAT=json

# ===========================================
# 🔒 Advanced Security Settings
# ===========================================

# JWT Token Settings
NOVABACKUP_JWT_ACCESS_TOKEN_EXPIRE=3600
NOVABACKUP_JWT_REFRESH_TOKEN_EXPIRE=604800
NOVABACKUP_JWT_ALGORITHM=HS256

# Password Policy
NOVABACKUP_PASSWORD_MIN_LENGTH=12
NOVABACKUP_PASSWORD_REQUIRE_UPPERCASE=true
NOVABACKUP_PASSWORD_REQUIRE_LOWERCASE=true
NOVABACKUP_PASSWORD_REQUIRE_DIGIT=true
NOVABACKUP_PASSWORD_REQUIRE_SPECIAL=true

# Session Settings
NOVABACKUP_SESSION_TIMEOUT=28800
NOVABACKUP_SESSION_SECURE_COOKIE=true
NOVABACKUP_SESSION_SAME_SITE=lax

# Rate Limiting (authentication)
NOVABACKUP_AUTH_RATE_LIMIT=5
NOVABACKUP_AUTH_RATE_LIMIT_PERIOD=900

# ===========================================
# 🗄️ Database-Specific Examples
# ===========================================

# PostgreSQL (local)
# NOVABACKUP_DATABASE_URL=postgresql://novabackup:password@localhost:5432/novabackup

# PostgreSQL (remote with SSL)
# NOVABACKUP_DATABASE_URL=postgresql://novabackup:password@db.example.com:5432/novabackup?sslmode=require

# MySQL/MariaDB
# NOVABACKUP_DATABASE_URL=mysql://novabackup:password@localhost:3306/novabackup

# MSSQL (SQL Server)
# NOVABACKUP_DATABASE_URL=mssql://novabackup:password@localhost:1433/novabackup?driver=ODBC+Driver+17+for+SQL+Server

# Oracle
# NOVABACKUP_DATABASE_URL=oracle://novabackup:password@localhost:1521/orcl

# SQLite (file-based)
# NOVABACKUP_DATABASE_URL=sqlite:///./novabackup.db

# SQLite (in-memory, for testing)
# NOVABACKUP_DATABASE_URL=sqlite:///:memory:

# ===========================================
# 🐳 Docker-Specific Configuration
# ===========================================
# Use these when running in Docker/Docker Compose

# Database (Docker Compose service name)
NOVABACKUP_DATABASE_URL=postgresql://novabackup:novabackup_password@db:5432/novabackup

# Paths (mounted volumes)
NOVABACKUP_BACKUP_DIR=/backups
NOVABACKUP_DATA_DIR=/data
NOVABACKUP_LOGS_DIR=/logs

# Server (container networking)
NOVABACKUP_HOST=0.0.0.0
NOVABACKUP_PORT=8000

# ===========================================
# 📊 Resource Limits
# ===========================================
# Configure resource usage limits

# Memory limits (in MB)
NOVABACKUP_MAX_MEMORY_MB=1024
NOVABACKUP_BACKUP_MAX_MEMORY_MB=512

# CPU limits (percentage)
NOVABACKUP_MAX_CPU_PERCENT=80

# Disk space limits (in GB)
NOVABACKUP_MIN_FREE_DISK_GB=10
NOVABACKUP_MAX_BACKUP_SIZE_GB=100

# Network bandwidth limits (in Mbps, 0 = unlimited)
NOVABACKUP_MAX_BANDWIDTH_MBPS=0

# ===========================================
# 🔄 Backup Advanced Settings
# ===========================================

# Compression (gzip, bz2, xz, none)
NOVABACKUP_COMPRESSION=gzip
NOVABACKUP_COMPRESSION_LEVEL=6

# Encryption
NOVABACKUP_ENCRYPTION_ENABLED=true
NOVABACKUP_ENCRYPTION_ALGORITHM=AES-256-GCM

# Parallel Operations
NOVABACKUP_BACKUP_WORKERS=4
NOVABACKUP_RESTORE_WORKERS=4

# Retry Settings
NOVABACKUP_MAX_RETRIES=3
NOVABACKUP_RETRY_DELAY=5
NOVABACKUP_RETRY_BACKOFF=exponential

# ===========================================
# 🌐 Proxy Configuration
# ===========================================
# If behind corporate proxy

# HTTP Proxy
# NOVABACKUP_HTTP_PROXY=http://proxy.example.com:8080
# NOVABACKUP_HTTPS_PROXY=http://proxy.example.com:8080

# No Proxy (comma-separated list)
# NOVABACKUP_NO_PROXY=localhost,127.0.0.1,.local

# ===========================================
# 🎯 Feature Flags
# ===========================================
# Enable/disable specific features

# Enable experimental features
NOVABACKUP_EXPERIMENTAL=false

# Enable API documentation (Swagger/OpenAPI)
NOVABACKUP_API_DOCS_ENABLED=true

# Enable web dashboard
NOVABACKUP_DASHBOARD_ENABLED=true

# Enable CLI commands
NOVABACKUP_CLI_ENABLED=true

# Enable cloud providers
NOVABACKUP_CLOUD_ENABLED=true

# ===========================================
# 📝 Custom Metadata
# ===========================================
# Add custom metadata to backups

# Organization name
NOVABACKUP_ORG_NAME=Your Organization

# Environment tags
NOVABACKUP_TAGS=production,backup,critical

# Contact information
NOVABACKUP_CONTACT_EMAIL=admin@yourdomain.com
NOVABACKUP_CONTACT_PHONE=+1-555-123-4567

# ===========================================
# 🔧 Debug & Development
# ===========================================
# Use only in development, NEVER in production!

# Enable detailed error messages
# NOVABACKUP_DEBUG=true

# Enable SQL query logging
# NOVABACKUP_LOG_SQL=true

# Enable slow query logging (ms)
# NOVABACKUP_SLOW_QUERY_THRESHOLD=1000

# Enable request logging
# NOVABACKUP_LOG_REQUESTS=true

# Disable authentication (development only!)
# NOVABACKUP_DISABLE_AUTH=false

# Pre-populate test users (development only!)
# NOVABACKUP_SEED_USERS=true

# ===========================================
# End of Configuration Examples
# ===========================================
