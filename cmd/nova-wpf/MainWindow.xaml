<Window x:Class="NovaBackup.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NovaBackup Enterprise v6.0 - Backup and Recovery Platform"
        Height="800" Width="1400"
        WindowStyle="SingleBorderWindow"
        Background="#F0F0F0">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ribbon Menu (Veeam Style) -->
        <TabControl Grid.Row="0" Background="#0078D7">
            <TabItem Header="🏠 Home" FontSize="14" Padding="16,8" Margin="2,0,0,0">
                <StackPanel Orientation="Horizontal" Margin="8,4">
                    <Button x:Name="btnNewJob" Content="💾 New Job" Width="80" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#1976D2" Foreground="White" Margin="4"/>
                    <Button x:Name="btnRunNow" Content="▶ Run" Width="80" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#388E3C" Foreground="White" Margin="4"/>
                    <Separator Width="2" Margin="8,4" Background="#B0BEC5"/>
                    <Button x:Name="btnRestore" Content="🔄 Restore" Width="80" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#FF9800" Foreground="White" Margin="4"/>
                    <Button x:Name="btnVerify" Content="✓ Verify" Width="80" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#9C27B0" Foreground="White" Margin="4"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="📋 Jobs" FontSize="14" Padding="16,8">
                <StackPanel Orientation="Horizontal" Margin="8,4">
                    <Button x:Name="btnCreateJob" Content="➕ Create" Width="80" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#1976D2" Foreground="White" Margin="4"/>
                    <Button x:Name="btnEditJob" Content="✏️ Edit" Width="80" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#5C6BC0" Foreground="White" Margin="4"/>
                    <Button x:Name="btnDeleteJob" Content="🗑️ Delete" Width="80" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#F44336" Foreground="White" Margin="4"/>
                    <Separator Width="2" Margin="8,4" Background="#B0BEC5"/>
                    <Button x:Name="btnEnableJob" Content="✅ Enable" Width="80" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#4CAF50" Foreground="White" Margin="4"/>
                    <Button x:Name="btnDisableJob" Content="⏸️ Disable" Width="80" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#FFC107" Foreground="White" Margin="4"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="🏗️ Infrastructure" FontSize="14" Padding="16,8">
                <StackPanel Orientation="Horizontal" Margin="8,4">
                    <Button x:Name="btnAddRepo" Content="📁 Add Repository" Width="100" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#009688" Foreground="White" Margin="4"/>
                    <Button x:Name="btnAddServer" Content="🖥️ Add Server" Width="90" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#00BCD4" Foreground="White" Margin="4"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="📊 Monitoring" FontSize="14" Padding="16,8">
                <StackPanel Orientation="Horizontal" Margin="8,4">
                    <Button x:Name="btnSessions" Content="📋 Sessions" Width="90" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#3F51B5" Foreground="White" Margin="4"/>
                    <Button x:Name="btnAlarms" Content="⚠️ Alarms" Width="90" Height="60"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#FF5722" Foreground="White" Margin="4"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Inventory Tree (Veeam Style) -->
            <Border Grid.Column="0" Background="White" BorderBrush="#CCCCCC" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#0078D7" Padding="8,6">
                        <TextBlock Text="📂 Inventory" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <TreeView x:Name="inventoryTree" Grid.Row="1" Background="White" BorderThickness="0">
                        <TreeViewItem Header="🏗️ Backup Infrastructure" IsExpanded="True">
                            <TreeViewItem Header="📊 Dashboard">
                                <TreeViewItem.HeaderTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📊 Dashboard" Margin="4,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </TreeViewItem.HeaderTemplate>
                            </TreeViewItem>
                            <TreeViewItem Header="💾 Backup Jobs" IsExpanded="True">
                                <TreeViewItem Header="📄 Daily Documents Backup"/>
                                <TreeViewItem Header="🖥️ Weekly System Backup"/>
                                <TreeViewItem Header="☁️ Cloud Sync Job"/>
                            </TreeViewItem>
                            <TreeViewItem Header="📁 Backup Repositories">
                                <TreeViewItem Header="📂 Local Repository (D:\Backups)"/>
                                <TreeViewItem Header="🌐 SMB Share (\\server\backup)"/>
                            </TreeViewItem>
                        </TreeViewItem>
                        <TreeViewItem Header="🔄 Replication" IsExpanded="False">
                            <TreeViewItem Header="📋 Replication Jobs"/>
                        </TreeViewItem>
                        <TreeViewItem Header="📈 History" IsExpanded="False">
                            <TreeViewItem Header="📊 Sessions"/>
                            <TreeViewItem Header="⚠️ Warnings"/>
                            <TreeViewItem Header="🔴 Errors"/>
                        </TreeViewItem>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Right Panel - Data Grid (Veeam Style) -->
            <Border Grid.Column="1" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Margin="8,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#0078D7" Padding="8,6">
                        <TextBlock Text="📋 Backup Jobs" FontWeight="Bold" Foreground="White"/>
                    </Border>

                    <DataGrid x:Name="jobsGrid" Grid.Row="1" AutoGenerateColumns="False"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              RowHeight="40"
                              HeadersVisibility="Column">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="Foreground" Value="#1565C0"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderBrush" Value="#BBDEFB"/>
                                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="1*"/>
                            <DataGridTemplateColumn Header="Status" Width="1.5*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding StatusIcon}" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Status}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Last Run" Binding="{Binding LastRun}" Width="1.5*"/>
                            <DataGridTextColumn Header="Next Run" Binding="{Binding NextRun}" Width="1.5*"/>
                            <DataGridTextColumn Header="Schedule" Binding="{Binding Schedule}" Width="1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar (Veeam Style) -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,4">
                    <TextBlock x:Name="statusService" Text="🟢 Service: Running" Margin="0,0,16,0" FontWeight="Bold"/>
                    <TextBlock Text="|" Margin="8,0"/>
                    <TextBlock x:Name="statusJobs" Text="📊 Jobs: 3 Active" Margin="16,0,0,0"/>
                    <TextBlock Text="|" Margin="8,0"/>
                    <TextBlock Text="💾 Storage: 1.2 TB Used" Margin="16,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,4">
                    <Button x:Name="btnHelp" Content="❓ Help" Padding="12,4" Margin="4,0"/>
                    <Button x:Name="btnAbout" Content="ℹ️ About" Padding="12,4" Margin="4,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
