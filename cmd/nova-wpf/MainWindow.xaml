<Window x:Class="NovaBackup.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NovaBackup Enterprise v6.0 - Платформа Резервного Копіювання та Відновлення"
        Height="900" Width="1500"
        WindowStyle="SingleBorderWindow"
        Background="#1a1a2e"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Dark Theme Colors -->
        <SolidColorBrush x:Key="PrimaryDark" Color="#16213e"/>
        <SolidColorBrush x:Key="SecondaryDark" Color="#1a1a2e"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#0f3460"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#e94560"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#059669"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#7c3aed"/>
        <SolidColorBrush x:Key="AccentAmber" Color="#d97706"/>
        <SolidColorBrush x:Key="TextLight" Color="#e8e8e8"/>
        <SolidColorBrush x:Key="TextMuted" Color="#a0a0a0"/>
        <SolidColorBrush x:Key="CardBackground" Color="#1f2937"/>
        <SolidColorBrush x:Key="HoverBackground" Color="#2d3748"/>

        <!-- 3D Button Style -->
        <Style x:Key="Button3D" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="MinHeight" Value="55"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#000000"
                                BorderThickness="0,3,0,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  Direction="270"
                                                  ShadowDepth="2"
                                                  BlurRadius="6"
                                                  Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource HoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                <Setter Property="BorderBrush" Value="#000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 3D Card Style -->
        <Style x:Key="Card3D" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000"
                                      Direction="315"
                                      ShadowDepth="4"
                                      BlurRadius="12"
                                      Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ribbon Tab Style -->
        <Style x:Key="RibbonTab3D" TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="MinHeight" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8,8,0,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}"
                                MinHeight="{TemplateBinding MinHeight}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000"
                                                  Direction="270"
                                                  ShadowDepth="2"
                                                  BlurRadius="6"
                                                  Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentOrange}"/>
                                <Setter TargetName="Border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#e94560"
                                                          Direction="270"
                                                          ShadowDepth="2"
                                                          BlurRadius="10"
                                                          Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1a4a7a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Dark Style -->
        <Style x:Key="DataGridDark" TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowHeight" Value="45"/>
            <Setter Property="ColumnHeaderHeight" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- TreeView Dark Style -->
        <Style x:Key="TreeViewDark" TargetType="TreeView">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 3D Ribbon Menu -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryDark}" Padding="0,0,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="4" BlurRadius="15" Opacity="0.5"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Border Grid.Column="0" Background="{StaticResource AccentOrange}" Padding="20,15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛡️" FontSize="32" VerticalAlignment="Center"/>
                        <StackPanel Margin="15,0,0,0">
                            <TextBlock Text="NovaBackup Enterprise" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="v6.0 - Система Резервного Копіювання" FontSize="12" Foreground="#f0f0f0" Opacity="0.8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Ribbon Tabs -->
                <TabControl Grid.Column="1" Background="Transparent" BorderThickness="0">
                    <TabItem Style="{StaticResource RibbonTab3D}" Header="🏠 Головна">
                        <StackPanel Orientation="Horizontal" Margin="10,8">
                            <Button x:Name="btnNewJob" Content="💾 Нове Завдання" Style="{StaticResource Button3D}" Margin="3"/>
                            <Button x:Name="btnRunNow" Content="▶ Запуск" Style="{StaticResource Button3D}" Background="{StaticResource AccentGreen}" Margin="3"/>
                            <Separator Width="2" Margin="10,0" Background="#374151"/>
                            <Button x:Name="btnRestore" Content="🔄 Відновлення" Style="{StaticResource Button3D}" Background="{StaticResource AccentAmber}" Margin="3"/>
                            <Button x:Name="btnVerify" Content="✓ Перевірка" Style="{StaticResource Button3D}" Background="{StaticResource AccentPurple}" Margin="3"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Style="{StaticResource RibbonTab3D}" Header="📋 Завдання">
                        <StackPanel Orientation="Horizontal" Margin="10,8">
                            <Button x:Name="btnCreateJob" Content="➕ Створити" Style="{StaticResource Button3D}" Margin="3"/>
                            <Button x:Name="btnEditJob" Content="✏️ Редагувати" Style="{StaticResource Button3D}" Background="{StaticResource AccentPurple}" Margin="3"/>
                            <Button x:Name="btnDeleteJob" Content="🗑️ Видалити" Style="{StaticResource Button3D}" Background="#dc2626" Margin="3"/>
                            <Separator Width="2" Margin="10,0" Background="#374151"/>
                            <Button x:Name="btnEnableJob" Content="✅ Увімкнути" Style="{StaticResource Button3D}" Background="{StaticResource AccentGreen}" Margin="3"/>
                            <Button x:Name="btnDisableJob" Content="⏸️ Вимкнути" Style="{StaticResource Button3D}" Background="{StaticResource AccentAmber}" Margin="3"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Style="{StaticResource RibbonTab3D}" Header="🏗️ Інфраструктура">
                        <StackPanel Orientation="Horizontal" Margin="10,8">
                            <Button x:Name="btnAddRepo" Content="📁 Додати Сховище" Style="{StaticResource Button3D}" Background="#0891b2" Margin="3"/>
                            <Button x:Name="btnAddServer" Content="🖥️ Додати Сервер" Style="{StaticResource Button3D}" Background="#0284c7" Margin="3"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Style="{StaticResource RibbonTab3D}" Header="📊 Моніторинг">
                        <StackPanel Orientation="Horizontal" Margin="10,8">
                            <Button x:Name="btnSessions" Content="📋 Сесії" Style="{StaticResource Button3D}" Background="#4f46e5" Margin="3"/>
                            <Button x:Name="btnAlarms" Content="⚠️ Сповіщення" Style="{StaticResource Button3D}" Background="#dc2626" Margin="3"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!-- Main Content Area with 3D Effect -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Inventory Tree -->
            <Border Grid.Column="0" Style="{StaticResource Card3D}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource AccentBlue}" Padding="15,12" CornerRadius="12,12,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂 Інвентар" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="  ·  3 об'єкти" FontSize="14" Foreground="#a5b4fc" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TreeView x:Name="inventoryTree" Grid.Row="1" Style="{StaticResource TreeViewDark}" Background="Transparent">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Margin" Value="2,0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource HoverBackground}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.ItemContainerStyle>

                        <TreeViewItem Header="🏗️ Інфраструктура Резервного Копіювання" IsExpanded="True" FontWeight="Bold">
                            <TreeViewItem Header="📊 Панель Керування"/>
                            <TreeViewItem Header="💾 Завдання Резервного Копіювання" IsExpanded="True">
                                <TreeViewItem Header="📄 Щоденне Резервне Копіювання Документів"/>
                                <TreeViewItem Header="🖥️ Тижнева Резервна Копія Системи"/>
                                <TreeViewItem Header="☁️ Синхронізація Хмари"/>
                            </TreeViewItem>
                            <TreeViewItem Header="📁 Сховища Резервних Копій">
                                <TreeViewItem Header="📂 Локальне Сховище (D:\Backups)"/>
                                <TreeViewItem Header="🌐 SMB Частка (\\server\backup)"/>
                            </TreeViewItem>
                        </TreeViewItem>
                        <TreeViewItem Header="🔄 Реплікація">
                            <TreeViewItem Header="📋 Завдання Реплікації"/>
                        </TreeViewItem>
                        <TreeViewItem Header="📈 Історія">
                            <TreeViewItem Header="📊 Сесії"/>
                            <TreeViewItem Header="⚠️ Попередження"/>
                            <TreeViewItem Header="🔴 Помилки"/>
                        </TreeViewItem>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Right Panel - Data Grid -->
            <Border Grid.Column="1" Style="{StaticResource Card3D}" Margin="20,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource AccentBlue}" Padding="15,12" CornerRadius="12,12,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 Завдання Резервного Копіювання" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="  ·  Активні: 3" FontSize="14" Foreground="#86efac" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="jobsGrid" Grid.Row="1" AutoGenerateColumns="False"
                              Style="{StaticResource DataGridDark}"
                              RowHeight="50" CanUserAddRows="False">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="FontSize" Value="14"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="12,4"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource HoverBackground}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Назва" Binding="{Binding Name}" Width="2*"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="0.8*"/>
                            <DataGridTemplateColumn Header="Статус" Width="1*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding StatusIcon}" FontSize="18" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Foreground="{StaticResource TextLight}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Останній Запуск" Binding="{Binding LastRun}" Width="1.2*"/>
                            <DataGridTextColumn Header="Наступний Запуск" Binding="{Binding NextRun}" Width="1.2*"/>
                            <DataGridTextColumn Header="Розклад" Binding="{Binding Schedule}" Width="1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar with 3D Effect -->
        <Border Grid.Row="2" Background="{StaticResource PrimaryDark}" Padding="20,12" Margin="0,0,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Direction="90" ShadowDepth="2" BlurRadius="8" Opacity="0.3"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="{StaticResource CardBackground}" CornerRadius="6" Padding="15,8" Margin="0,0,15,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" Direction="270" ShadowDepth="1" BlurRadius="4" Opacity="0.3"/>
                        </Border.Effect>
                        <TextBlock x:Name="statusService" Text="🟢 Служба: Працює" FontWeight="Bold" Foreground="{StaticResource TextLight}"/>
                    </Border>

                    <Border Background="{StaticResource CardBackground}" CornerRadius="6" Padding="15,8" Margin="0,0,15,0">
                        <TextBlock x:Name="statusJobs" Text="📊 Завдання: 3 Активні" Foreground="{StaticResource TextLight}"/>
                    </Border>

                    <Border Background="{StaticResource CardBackground}" CornerRadius="6" Padding="15,8">
                        <TextBlock Text="💾 Сховище: 1.2 TB Використано" Foreground="{StaticResource TextLight}"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnHelp" Content="❓ Довідка" Padding="20,10" Margin="0,0,10,0" Style="{StaticResource Button3D}" Background="#4f46e5" Click="BtnHelp_Click"/>
                    <Button x:Name="btnAbout" Content="ℹ️ Про Програмy" Padding="20,10" Style="{StaticResource Button3D}" Background="#7c3aed" Click="BtnAbout_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
