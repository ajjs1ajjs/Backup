<Window x:Class="NovaBackup.WPF.SessionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Backup Sessions History" Height="500" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#3F51B5" Padding="15,10" Margin="-20,-20,-20,20">
            <TextBlock Text="📊 Backup Sessions History" FontSize="20" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Data Grid -->
        <DataGrid Grid.Row="1" AutoGenerateColumns="False"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1" BorderBrush="#CCCCCC"
                  RowHeight="40"
                  HeadersVisibility="Column">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="Foreground" Value="#1565C0"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="8,4"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Job Name" Binding="{Binding JobName}" Width="2*"/>
                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTime}" Width="1.5*"/>
                <DataGridTextColumn Header="End Time" Binding="{Binding EndTime}" Width="1.5*"/>
                <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" Width="1*"/>
                <DataGridTemplateColumn Header="Status" Width="1.5*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding StatusIcon}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Status}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Processed" Binding="{Binding Processed}" Width="1*"/>
                <DataGridTextColumn Header="Transferred" Binding="{Binding Transferred}" Width="1*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnRefresh" Content="🔄 Refresh" Width="100" Height="35" Margin="0,0,10,0" Click="BtnRefresh_Click"/>
            <Button x:Name="btnClose" Content="Close" Width="100" Height="35" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
