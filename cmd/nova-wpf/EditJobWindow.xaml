<Window x:Class="NovaBackup.WPF.EditJobWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Backup Job" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#5C6BC0" Padding="15,10" Margin="-20,-20,-20,20">
            <TextBlock Text="✏️ Edit Backup Job" FontSize="20" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Job Name:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtName" Height="30" Margin="0,0,0,15"/>

                <TextBlock Text="Description:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDescription" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>

                <TextBlock Text="Destination:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDestination" Height="30" Margin="0,0,0,15"/>

                <CheckBox x:Name="chkCompression" Content="Enable Compression" Margin="0,5"/>
                <CheckBox x:Name="chkEncryption" Content="Enable Encryption (AES-256)" Margin="0,5,0,15"/>

                <TextBlock Text="Schedule:" Margin="0,0,0,5"/>
                <ComboBox x:Name="cmbSchedule" Height="30" Margin="0,0,0,15">
                    <ComboBoxItem Content="Daily"/>
                    <ComboBoxItem Content="Weekly"/>
                    <ComboBoxItem Content="Monthly"/>
                </ComboBox>

                <TextBlock Text="Time:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtTime" Height="30" Width="100" HorizontalAlignment="Left"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnCancel" Content="Cancel" Width="100" Height="35" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="btnSave" Content="Save" Width="100" Height="35" Background="#388E3C" Foreground="White" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
