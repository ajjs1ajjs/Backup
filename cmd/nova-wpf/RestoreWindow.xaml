<Window x:Class="NovaBackup.WPF.RestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Restore Wizard" Height="600" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF9800" Padding="15,10" Margin="-20,-20,-20,20">
            <TextBlock Text="🔄 Restore Wizard" FontSize="20" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Wizard Steps -->
        <TabControl Grid.Row="1" Margin="0,0,0,20">
            <TabItem Header="1. Select Backup">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Available Restore Points:" Margin="0,0,0,10"/>
                    <ListBox Grid.Row="1" x:Name="lstBackups">
                        <ListBoxItem Content="📦 Daily Documents Backup - 2026-03-14 02:00 (1.2 GB)"/>
                        <ListBoxItem Content="📦 Daily Documents Backup - 2026-03-13 02:00 (1.1 GB)"/>
                        <ListBoxItem Content="📦 Weekly System Backup - 2026-03-09 22:00 (45.6 GB)"/>
                        <ListBoxItem Content="📦 Cloud Sync - 2026-03-10 06:00 (2.3 GB)"/>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="2. Select Files">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="✅ Select All" Padding="15,8" Margin="0,0,10,0"/>
                        <Button Content="❌ Deselect All" Padding="15,8"/>
                    </StackPanel>

                    <TreeView Grid.Row="1" x:Name="treeFiles">
                        <TreeViewItem Header="📁 Documents" IsExpanded="True">
                            <TreeViewItem Header="📄 report.docx"/>
                            <TreeViewItem Header="📄 budget.xlsx"/>
                            <TreeViewItem Header="📄 presentation.pptx"/>
                        </TreeViewItem>
                        <TreeViewItem Header="📁 Pictures">
                            <TreeViewItem Header="🖼️ photo1.jpg"/>
                            <TreeViewItem Header="🖼️ photo2.jpg"/>
                        </TreeViewItem>
                    </TreeView>
                </Grid>
            </TabItem>

            <TabItem Header="3. Destination">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <RadioButton Grid.Row="0" x:Name="rbOriginal" Content="Restore to original location" GroupName="Dest" IsChecked="True" Margin="0,0,0,15"/>

                    <RadioButton Grid.Row="1" Content="Restore to:" GroupName="Dest" Margin="0,0,0,15"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="20,0,0,15">
                        <TextBox x:Name="txtPath" Width="400" Text="C:\Restored"/>
                        <Button Content="Browse..." Margin="10,0,0,0" Padding="15,5"/>
                    </StackPanel>

                    <CheckBox Grid.Row="3" Content="Restore NTFS permissions" IsChecked="True"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnCancel" Content="Cancel" Width="100" Height="35" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="btnRestore" Content="🔄 Restore Now" Width="120" Height="35" Background="#FF9800" Foreground="White" Click="BtnRestore_Click"/>
        </StackPanel>
    </Grid>
</Window>
